{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": [
    "dependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update PostgreSQL test service images",
      "managerFilePatterns": [
        "/^\\.github/workflows/(?:ci|coverage-pages|release)\\.yml$/"
      ],
      "matchStrings": [
        "'postgres:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})'",
        "image: postgres:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update digest-pinned CI and release utility containers",
      "managerFilePatterns": [
        "/^\\.github/workflows/(?:ci|release)\\.yml$/"
      ],
      "matchStrings": [
        "(?<depName>koalaman/shellcheck):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "(?<depName>ghcr.io/yannh/kubeconform):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "(?<depName>moby/buildkit):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update digest-pinned QEMU binfmt images",
      "managerFilePatterns": [
        "/^\\.github/workflows/(?:ci|release)\\.yml$/"
      ],
      "matchStrings": [
        "(?<depName>tonistiigi/binfmt):(?<currentValue>qemu-v[0-9]+\\.[0-9]+\\.[0-9]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^qemu-v(?<major>[0-9]+)\\.(?<minor>[0-9]+)\\.(?<patch>[0-9]+)$"
    },
    {
      "customType": "regex",
      "description": "Update the pinned Docker Buildx client",
      "managerFilePatterns": [
        "/^\\.github/workflows/(?:ci|release)\\.yml$/"
      ],
      "matchStrings": [
        "docker/setup-buildx-action@[^\\s]+\\s+# [^\\n]+\\n\\s+with:\\n\\s+version: v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "depNameTemplate": "docker/buildx",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)$",
      "versioningTemplate": "semver"
    }
  ],
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Group non-major Python development dependency updates",
      "matchDepTypes": [
        "dependency-groups"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Python development dependencies"
    },
    {
      "description": "Let Dependabot own GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "enabled": false
    },
    {
      "description": "Update the uv image, executable, and setup action together",
      "matchPackageNames": [
        "astral-sh/setup-uv",
        "astral-sh/uv",
        "ghcr.io/astral-sh/uv"
      ],
      "groupName": "uv toolchain",
      "enabled": true
    },
    {
      "description": "Refresh container digests weekly",
      "matchUpdateTypes": [
        "digest"
      ],
      "schedule": [
        "before 6am on monday"
      ]
    }
  ],
  "prConcurrentLimit": 5,
  "rangeStrategy": "update-lockfile"
}
