# Safe local-development defaults. Copy to .env, then uncomment and fill the
# GitHub App values only for a disposable development installation.
EXTRA_CODEOWNERS_ENVIRONMENT=development
EXTRA_CODEOWNERS_LOG_LEVEL=INFO
EXTRA_CODEOWNERS_HOST=127.0.0.1
EXTRA_CODEOWNERS_PORT=8000
EXTRA_CODEOWNERS_DATABASE_URL=sqlite:///./extra-codeowners.db

# EXTRA_CODEOWNERS_GITHUB_APP_ID=123456
# EXTRA_CODEOWNERS_GITHUB_PRIVATE_KEY_FILE=./extra-codeowners.private-key.pem
# EXTRA_CODEOWNERS_GITHUB_WEBHOOK_SECRET_FILE=./extra-codeowners.webhook-secret
# EXTRA_CODEOWNERS_PUBLIC_URL=https://extra-codeowners.example.test

EXTRA_CODEOWNERS_WORKER_ENABLED=true
EXTRA_CODEOWNERS_WORKER_RETRY_MAX_SECONDS=60
EXTRA_CODEOWNERS_RECONCILE_ENABLED=true
EXTRA_CODEOWNERS_RECONCILE_INTERVAL_SECONDS=300
EXTRA_CODEOWNERS_WEBHOOK_DELIVERY_RETENTION_DAYS=30

# This removes built-in sensitive-path protections. Keep it false unless the
# deployment owner has deliberately accepted the threat-model consequences.
EXTRA_CODEOWNERS_ALLOW_INSECURE_CHANGES=false

# App Manifest registration is a temporary operator workflow. Keep it off for
# ordinary service operation; see docs/how-to/register-app.md before enabling.
EXTRA_CODEOWNERS_SETUP_ENABLED=false
